{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/post_edit.py",
        "windows": "python .github\\hooks\\scripts\\post_edit.py",
        "timeout": 30
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/session_context.py",
        "windows": "python .github\\hooks\\scripts\\session_context.py",
        "timeout": 15
      }
    ]
  }
}
