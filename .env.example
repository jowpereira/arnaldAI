# Azure OpenAI — exemplo simples (copie para .env e preencha valores reais)

# ─── Fluxo simples recomendado ───────────────────────────────
# Basta informar um endpoint, uma chave e um model/deployment.
# O Arnaldo reutiliza esse mesmo valor em GOD/EXPERT/FAST e,
# se o endpoint for /openai/v1, também no tier CODEX.
AZURE_OPENAI_ENDPOINT=https://<recurso>.services.ai.azure.com/api/projects/<project>/openai/v1
AZURE_OPENAI_API_KEY=<sua-chave-api>
AZURE_OPENAI_MODEL=<seu-model-ou-deployment>
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ─── Overrides avançados (opcionais) ─────────────────────────
# Descomente só se quiser tiers diferentes.
# AZURE_TIER_GOD_DEPLOYMENT=god-tier
# AZURE_TIER_EXPERT_DEPLOYMENT=expert-tier
# AZURE_TIER_FAST_DEPLOYMENT=fast-tier

# ─── CODEX separado (opcional) ───────────────────────────────
# Só use se quiser um recurso/base diferente para geração de código.
# AZURE_CODEX_BASE_URL=https://<seu-codex-recurso>.services.ai.azure.com/api/projects/<codex-project>/openai/v1
# AZURE_CODEX_DEPLOYMENT=gpt-5.3-codex
# AZURE_CODEX_REASONING_EFFORT=xhigh
# AZURE_CODEX_REASONING_SUMMARY=auto
# AZURE_CODEX_API_KEY=

# ─── Comportamento ───────────────────────────────────────────
ARNALDO_LLM_ENABLED=true
ARNALDO_LLM_TIMEOUT_SECONDS=120
ARNALDO_LLM_MAX_TOKENS_DEFAULT=2000
